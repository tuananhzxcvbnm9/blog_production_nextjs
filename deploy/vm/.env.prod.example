# App
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_SITE_URL=https://blog.example.com
AUTH_SECRET=replace_with_strong_random_secret

# Database
POSTGRES_USER=blog
POSTGRES_PASSWORD=replace_with_strong_db_password
POSTGRES_DB=blog
DATABASE_URL=postgresql://blog:replace_with_strong_db_password@postgres:5432/blog

# S3
AWS_REGION=us-east-1
S3_BUCKET=your-s3-bucket
S3_PUBLIC_BASE_URL=https://cdn.example.com
S3_UPLOAD_PREFIX=uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional
SENTRY_DSN=
